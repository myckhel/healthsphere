APP_NAME=HealthSphere API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://healthsphere:healthsphere@localhost:5432/healthsphere
DATABASE_URL_SYNC=postgresql://healthsphere:healthsphere@localhost:5432/healthsphere

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

AUTH_MODE=stub
STUB_AUTH_HEADER=X-HealthSphere-Actor-Id
STUB_ROLE_HEADER=X-HealthSphere-Actor-Role
STUB_CLINIC_HEADER=X-HealthSphere-Clinic-Id

CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

CALENDLY_API_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
